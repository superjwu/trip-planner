# ── Clerk (Authentication) ─────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Supabase ───────────────────────────────────────────────────
# Get from https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── ChatGPT / Codex OAuth integration ──────────────────────────
# Master kill-switch. Set to "1" to enable Connect-with-ChatGPT.
# Set to anything else (or unset) to render the disabled banner instead.
CODEX_OAUTH_ENABLED=1
# 32+ character random string. Used as the master key for pgp_sym_encrypt
# of every user's stored OAuth tokens. Rotate by regenerating + re-saving
# all rows (no automated rotation flow yet).
# Generate with: openssl rand -hex 32
CODEX_TOKEN_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32-output

# ── Google Places (New) — for one-time photo prefetch only ─────
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_PLACES_API_KEY=AIza...

# ── Amadeus Self-Service (best-effort flight/hotel quotes) ─────
# Get from https://developers.amadeus.com → My Self-Service Workspace
AMADEUS_CLIENT_ID=...
AMADEUS_CLIENT_SECRET=...
# 'test' or 'production' (we use 'test' for v1)
AMADEUS_ENV=test

# ── (Optional) Anthropic — kept for offline scripts only ───────
# Not required at runtime; the runtime LLM path goes through Codex via
# user OAuth. Keep this if you want to run the seed-eval scripts that
# still reference @anthropic-ai/sdk in devDependencies.
# ANTHROPIC_API_KEY=sk-ant-...

# ── (Optional, dev only) ───────────────────────────────────────
# Bypass Clerk + service-role-as-owner shortcut for local exploration.
# DEV_BYPASS_AUTH=1
